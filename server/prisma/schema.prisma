generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  firstName            String
  lastName             String
  userName             String                @unique
  password             String
  birthdate            DateTime
  city                 String
  provinceId           Int
  address              String
  adoptionApplications AdoptionApplication[]
  province             Province              @relation(fields: [provinceId], references: [id])
}

model Province {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  organizations Organization[]
  users         User[]
}

model Organization {
  id                 String            @id @default(uuid())
  name               String
  email              String            @unique
  contactPerson      String?
  contactPersonRole  String?
  contactNumber      String
  password           String
  organizationType   String
  city               String
  provinceId         Int
  address            String
  yearEstablished    DateTime
  registrationNumber String?           @unique
  website            String?
  socialMediaLinks   String[]
  status             OperationalStatus
  numberOfAnimals    Int
  description        String
  province           Province          @relation(fields: [provinceId], references: [id])
  pets               Pets[]
}

model Pets {
  id                   String                @id @default(uuid())
  organizationId       String
  name                 String
  species              Species
  isMale               Boolean
  age                  Int
  size                 Size
  weight               Float
  color                String
  breedId              Int
  rescueStory          String
  dateRescued          DateTime
  adoptionReason       String
  temperament          Temperament
  isSpayedOrNeutered   Boolean
  isGoodWithDogs       Boolean
  isGoodWithCats       Boolean
  isGoodWithKids       Boolean
  isHouseTrained       Boolean
  isLeashTrained       Boolean
  adoptionFee          Float
  adoptionRequirements String[]
  adoptionStatus       AdoptionStatus        @default(AVAILABLE)
  adoptionApplications AdoptionApplication[]
  petConditions        PetCondition[]
  vaccinations         PetVaccination[]
  breed                Breed                 @relation(fields: [breedId], references: [id])
  organization         Organization          @relation(fields: [organizationId], references: [id])
}

model Breed {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  isCat Boolean
  pets  Pets[]
}

model PetVaccination {
  id               Int      @id @default(autoincrement())
  petId            String
  vaccineId        Int
  dateAdministered DateTime
  remarks          String?
  pet              Pets     @relation(fields: [petId], references: [id])
  vaccine          Vaccine  @relation(fields: [vaccineId], references: [id])

  @@unique([petId, vaccineId])
}

model Vaccine {
  id           Int              @id @default(autoincrement())
  name         String
  vaccinations PetVaccination[]
}

model PetCondition {
  id          Int              @id @default(autoincrement())
  petId       String
  conditionId Int
  condition   MedicalCondition @relation(fields: [conditionId], references: [id])
  pet         Pets             @relation(fields: [petId], references: [id])

  @@unique([petId, conditionId])
}

model MedicalCondition {
  id            Int            @id @default(autoincrement())
  name          String
  petConditions PetCondition[]
}

model AdoptionApplication {
  id        String                    @id @default(uuid())
  userId    String
  petId     String
  createdAt DateTime                  @default(now())
  status    AdoptionApplicationStatus @default(PENDING)
  pet       Pets                      @relation(fields: [petId], references: [id])
  user      User                      @relation(fields: [userId], references: [id])

  @@unique([userId, petId])
}

enum OperationalStatus {
  CATS
  DOGS
  BOTH
}

enum Size {
  SMALL
  MEDIUM
  LARGE
}

enum AdoptionStatus {
  AVAILABLE
  PENDING
  ADOPTED
}

enum Species {
  CAT
  DOG
}

enum Temperament {
  CALM
  PLAYFUL
  SHY
  FRIENDLY
  AGGRESSIVE
}

enum AdoptionApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  ADOPTED
}
