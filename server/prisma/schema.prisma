// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  firstName String
  lastName  String
  userName  String   @unique
  password  String
  birthdate DateTime
  city      String

  provinceId Int
  province   Province @relation(fields: [provinceId], references: [id])

  address String

  adoptionApplications AdoptionApplication[]
}

model Province {
  id   Int    @id @default(autoincrement())
  name String @unique

  users         User[]
  organizations Organization[]
}

model Organization {
  id                String  @id @default(uuid())
  name              String
  email             String  @unique
  contactPerson     String?
  contactPersonRole String?
  contactNumber     String
  password          String
  organizationType  String
  city              String

  provinceId Int
  province   Province @relation(fields: [provinceId], references: [id])

  address            String
  yearEstablished    DateTime
  registrationNumber String?           @unique
  website            String?
  socialMediaLinks   String[]
  status             OperationalStatus
  numberOfAnimals    Int
  description        String

  pets Pets[]
}

enum OperationalStatus {
  CATS
  DOGS
  BOTH
}

model Pets {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name   String
  species Species
  isMale Boolean
  age    Int
  size   Size
  weight Float
  color  String

  breedId Int
  breed   Breed @relation(fields: [breedId], references: [id])

  rescueStory    String
  dateRescued    DateTime
  adoptionReason String
  temperament    Temperament

  isSpayedOrNeutered Boolean
  isGoodWithDogs     Boolean
  isGoodWithCats     Boolean
  isGoodWithKids     Boolean
  isHouseTrained     Boolean
  isLeashTrained     Boolean

  vaccinations  PetVaccination[]
  petConditions PetCondition[]

  adoptionFee          Float
  adoptionRequirements String[]

  adoptionStatus AdoptionStatus @default(AVAILABLE)

  adoptionApplications AdoptionApplication[]
}

enum Size {
  SMALL
  MEDIUM
  LARGE
}

enum AdoptionStatus {
  AVAILABLE
  PENDING
  ADOPTED
}

enum Species {
  CAT
  DOG
}

model Breed {
  id    Int     @id @default(autoincrement())
  name  String @unique
  isCat Boolean

  pets Pets[]
}

enum Temperament {
  CALM
  PLAYFUL
  SHY
  FRIENDLY
  AGGRESSIVE
}

model PetVaccination {
  id Int @id @default(autoincrement())

  petId String
  pet   Pets   @relation(fields: [petId], references: [id])

  vaccineId Int
  vaccine   Vaccine @relation(fields: [vaccineId], references: [id])

  dateAdministered DateTime
  remarks          String?

  @@unique([petId, vaccineId])
}

model Vaccine {
  id   Int    @id @default(autoincrement())
  name String

  vaccinations PetVaccination[]
}

model PetCondition {
  id Int @id @default(autoincrement())

  petId String
  pet   Pets   @relation(fields: [petId], references: [id])

  conditionId Int
  condition   MedicalCondition @relation(fields: [conditionId], references: [id])

  @@unique([petId, conditionId])
}

model MedicalCondition {
  id   Int    @id @default(autoincrement())
  name String

  petConditions PetCondition[]
}

model AdoptionApplication {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  petId String
  pet   Pets   @relation(fields: [petId], references: [id])

  @@unique([userId, petId])
}
